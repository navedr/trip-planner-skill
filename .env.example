# Required
JWT_SECRET=change-me-to-a-random-secret
ENCRYPTION_KEY=generate-with-python-c-from-cryptography.fernet-import-Fernet;print(Fernet.generate_key().decode())

# Google Maps (required for map tab + geocoding)
GOOGLE_MAPS_API_KEY=

# ── Web Push (PWA notifications) ─────────────────────────────────
# Generate with: python3 scripts/generate_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Selenium Grid (for travel search tools)
SELENIUM_GRID_URL=http://host.docker.internal:4444

# ── LLM Configuration ─────────────────────────────────────────────
# Provider: "openai", "azure_openai", or "anthropic"
LLM_PROVIDER=openai

# API key (CLI/standalone) or fallback for web users without their own key
API_KEY=
DEFAULT_API_KEY=

# Reasoning effort for OpenAI/Azure models: low, medium, high
REASONING_EFFORT=medium

# ── OpenAI ────────────────────────────────────────────────────────
# MODEL=gpt-5
# BASE_URL=                              # optional, for proxies

# ── Azure OpenAI ─────────────────────────────────────────────────
# LLM_PROVIDER=azure_openai
# API_KEY=your-azure-api-key
# BASE_URL=https://your-resource.openai.azure.com
# MODEL=your-deployment-name             # e.g. gpt-4o, gpt-5
# API_VERSION=2024-12-01-preview

# ── Anthropic ─────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# API_KEY=sk-ant-...
# MODEL=claude-sonnet-4-20250514
